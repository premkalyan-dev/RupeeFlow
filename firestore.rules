rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. Users collection matching path
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) 
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 200
        && request.resource.data.monthlyBudget is number
        && request.resource.data.monthlyBudget > 0;
      allow delete: if false; // Prevent user state purging
    }

    // 2. Transactions collection matching path
    match /users/{userId}/transactions/{transactionId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.type is string
        && (request.resource.data.type == 'expense' || request.resource.data.type == 'saving')
        && request.resource.data.category is string
        && request.resource.data.category.size() <= 50
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 500
        && request.resource.data.date is string
        && request.resource.data.date.size() <= 20;
      allow delete: if isOwner(userId);
    }

    // 3. Savings Goals collection matching path
    match /users/{userId}/savingsGoals/{goalId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 150
        && request.resource.data.targetAmount is number
        && request.resource.data.targetAmount > 0
        && request.resource.data.currentAmount is number
        && request.resource.data.currentAmount >= 0
        && request.resource.data.category is string
        && request.resource.data.category.size() <= 50
        && request.resource.data.deadline is string
        && request.resource.data.deadline.size() <= 20;
      allow delete: if isOwner(userId);
    }
  }
}
