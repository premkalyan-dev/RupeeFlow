{
  "rewrites": [
    {
      "source": "/about",
      "destination": "/index.html"
    },
    {
      "source": "/contact",
      "destination": "/index.html"
    },
    {
      "source": "/privacy-policy",
      "destination": "/index.html"
    },
    {
      "source": "/tools",
      "destination": "/index.html"
    },
    {
      "source": "/emi-calculator",
      "destination": "/index.html"
    },
    {
      "source": "/sip-calculator",
      "destination": "/index.html"
    },
    {
      "source": "/savings-goal-calculator",
      "destination": "/index.html"
    },
    {
      "source": "/fd-calculator",
      "destination": "/index.html"
    },
    {
      "source": "/rd-calculator",
      "destination": "/index.html"
    },
    {
      "source": "/budget-planner",
      "destination": "/index.html"
    },
    {
      "source": "/dashboard",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/((?!assets/|favicon|robots\\.txt|sitemap\\.xml|ads\\.txt|site\\.webmanifest|.*\\.(?:png|jpg|jpeg|svg|ico|webp|txt|xml|json)$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' *; script-src 'self' 'unsafe-inline' 'unsafe-eval' *; style-src 'self' 'unsafe-inline' *; img-src 'self' data: blob: *; font-src 'self' data: *; connect-src 'self' *; frame-src 'self' *; object-src 'none'; base-uri 'self';"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
